# Copy this file to `.env` and fill in the values you need.
# Empty values are safe placeholders for local development.

# Core app runtime
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5432/super_agent
PDF_OUTPUT_DIR=generated-pdfs
AGENT_PDF_OUTPUT_DIR=generated-pdfs
FRONTEND_URL=http://127.0.0.1:3100
BACKEND_URL=http://127.0.0.1:8010
REDIS_URL=redis://127.0.0.1:63790/0
REDIS_HISTORY_MAX_MESSAGES=40
REDIS_HISTORY_TTL_SECONDS=2592000

# Tavily web search
TAVILY_API_KEY=
TAVILY_API_URL=https://api.tavily.com/search
TAVILY_SEARCH_URL=https://api.tavily.com/search
TAVILY_BASE_URL=

# Optional: real LLM provider keys.
# The app reads these three variables when you want real Qwen tool calling.
# Use your DashScope API key as OPENAI_API_KEY, and point OPENAI_BASE_URL to
# the DashScope OpenAI-compatible endpoint for your region.
#
# Typical Qwen values:
# OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxx
# OPENAI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# OPENAI_MODEL=qwen-plus
#
# Other common DashScope regions:
# Beijing:
#   https://dashscope.aliyuncs.com/compatible-mode/v1
# Singapore:
#   https://dashscope-intl.aliyuncs.com/compatible-mode/v1
# Virginia:
#   https://dashscope-us.aliyuncs.com/compatible-mode/v1
#
# Recommended model choices:
# - qwen-plus: balanced default for most agent workloads
# - qwen-max: stronger reasoning, usually slower and more expensive
# - qwen-turbo: lower latency and lower cost
OPENAI_API_KEY=
OPENAI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
OPENAI_MODEL=qwen-plus

# MCP server configuration
# Leave MCP_MOCK_ENABLED=true for local testing with the bundled demo server.
MCP_MOCK_ENABLED=true
MCP_TEST_MODE=true
MCP_SERVER_COMMAND=python -m app.mcp_demo_server
MCP_SERVER_CWD=
MCP_SERVER_TIMEOUT_SECONDS=20
MCP_SERVER_STARTUP_TIMEOUT_SECONDS=10
MCP_ALLOWED_ROOT=
MCP_APPROVAL_REQUIRED_TOOLS=dangerous_delete_file,send_email,delete_file

# Optional local-network override for tool testing.
ALLOW_LOCAL_TOOL_URLS=false

# Optional diagnostics
AGENT_NODE_TIMING=true
